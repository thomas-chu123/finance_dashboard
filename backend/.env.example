# ==========================================
# Supabase Configuration
# ==========================================
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==========================================
# Google OAuth Configuration
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
OAUTH_ENCRYPTION_KEY=your_oauth_encryption_key_32_chars_min

# ==========================================
# SMTP Configuration (Email Service)
# ==========================================
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ==========================================
# LINE API Configuration
# ==========================================
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_BOT_USER_ID=your_line_bot_user_id

# ==========================================
# AI & Briefing Service API Keys
# ==========================================
BRAVE_API_KEY=your_brave_search_api_key
GEMINI_API_KEY=your_google_gemini_api_key
TAVILY_API_KEY=your_tavily_api_key

# ==========================================
# SearXNG & Ollama Configuration
# ==========================================
SEARXNG_BASE_URL=http://localhost:8888
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ==========================================
# Application Configuration
# ==========================================
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your_secret_key_change_in_production

# ==========================================
# Redis Configuration
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# CORS Configuration
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ==========================================
# Optional: Rate Limiting & Security
# ==========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ==========================================
# FinMind API Configuration (Taiwan Stocks/ETFs)
# ==========================================
# FinMind 為台灣股票和 ETF 提供本地數據源
# 相比 Yahoo Finance，FinMind 的優勢：
#   - 拆股信息更新及時（避免 yfinance 的延遲問題）
#   - 股息調整準確（包括高股息 ETF 如 0056）
#   - TaiwanStockPriceAdj 數據集已自動調整股息和拆股
#
# 獲取方法：
#   1. 訪問 https://finmindtrade.com
#   2. 註冊帳戶並申請 API token
#   3. 將 token 設置在此環境變數
#
# 如未設置此變數，系統將自動回退到 Yahoo Finance
FinMind_API=your_finmind_api_token
